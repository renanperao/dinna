# Database (local docker)
DATABASE_URL=postgresql://pizzaria:pizzaria@localhost:5433/pizzaria

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_RESTAURANT_SLUG=pizzaria-do-ze

# Supabase — habilita Auth + Realtime no KDS.
# Em dev, deixe vazio para liberar acesso sem login (modo bypass).
# Para forçar login mesmo sem Supabase configurado: AUTH_BYPASS=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# AUTH_BYPASS=true  # opcional — força bypass em prod (não recomendado)

# Mercado Pago (placeholders — Phase 3)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Evolution API (placeholders — Phase 6)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# Resend (placeholder)
RESEND_API_KEY=
EMAIL_FROM=

# Cron protection
CRON_SECRET=dev-secret-change-me
